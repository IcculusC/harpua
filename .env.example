# Copy to .env (gitignored) to run the chat demo against a real model.
# With no .env the demo runs fully offline on the scripted mock.
#
#   pnpm --filter @harpua/api chat        # CLI REPL
#   pnpm --filter @harpua/api start       # HTTP on :3000

# The expected real path — one key, any model on openrouter.ai
# MODEL_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Named roles registered in apps/api (models preset; flip each with one var)
# FAST_MODEL_PROVIDER=openrouter    # deepseek/deepseek-v4-flash
# SMART_MODEL_PROVIDER=openrouter   # deepseek/deepseek-v4-pro
# TOOLS_MODEL_PROVIDER=openrouter   # openai/gpt-oss-120b

# Reply language for the demo's system prompt (BCP 47 tag; default en)
# CHAT_LANGUAGE=es

# Local alternatives
# MODEL_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5-coder:14b
# OLLAMA_BASE_URL=http://localhost:11434
