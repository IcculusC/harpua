# Which chat model backs the agent. Default: mock (deterministic, offline).
# Options: mock | openrouter | ollama | openai-compatible
MODEL_PROVIDER=mock

# HTTP port for the API server.
PORT=3000

# --- MODEL_PROVIDER=openrouter (recommended real arm) ------------------------
# One API key, every model — https://openrouter.ai. Many models are cheap and
# several are free (e.g. meta-llama/llama-3.1-8b-instruct). This is the expected
# path to run a real model: set the two vars below and MODEL_PROVIDER=openrouter.
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# --- Named roles (one key, many models) --------------------------------------
# agent.module.ts registers three roles, each with an ARM-SCOPED OpenRouter model
# preset, injectable via @InjectChatModel("fast" | "smart" | "tools"). With no
# env they all boot on the mock arm (keyless boot intact). Uncomment a line to
# flip that role real — the model id is already preset; the shared OPENROUTER_API_KEY
# above covers all three. (Prices ~as of 2026-07-07, per M input tokens.)
#   fast  -> deepseek/deepseek-v4-flash  (~$0.09/M)
#   smart -> deepseek/deepseek-v4-pro    (~$0.44/M)
#   tools -> openai/gpt-oss-120b         (~$0.03/M)
# FAST_MODEL_PROVIDER=openrouter
# SMART_MODEL_PROVIDER=openrouter
# TOOLS_MODEL_PROVIDER=openrouter

# --- MODEL_PROVIDER=ollama ---------------------------------------------------
# Requires a running Ollama daemon. No API key. OLLAMA_BASE_URL is optional
# (defaults to http://localhost:11434).
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# --- MODEL_PROVIDER=openai-compatible ----------------------------------------
# Any OpenAI-compatible server (vLLM, LM Studio, Together, ...).
# OPENAI_COMPATIBLE_BASE_URL is REQUIRED for this provider; the API key is
# optional (a placeholder is sent for keyless local servers).
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-...
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
