# Which chat model backs the agent. Default: mock (deterministic, offline).
# Options: mock | ollama | openai-compatible
MODEL_PROVIDER=mock

# HTTP port for the API server.
PORT=3000

# --- MODEL_PROVIDER=ollama ---------------------------------------------------
# Requires a running Ollama daemon. No API key.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- MODEL_PROVIDER=openai-compatible ----------------------------------------
# Any OpenAI-compatible server (OpenAI, vLLM, LM Studio, Together, ...).
# OPENAI_COMPATIBLE_BASE_URL is REQUIRED for this provider.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=sk-...
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
