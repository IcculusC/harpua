{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Harpua NestJS",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "target": "ES2023",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowJs": true,
    "declaration": false,
    "outDir": "./dist"
  }
}
